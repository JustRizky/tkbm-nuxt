// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../app/generated/prisma/"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  PENGURUS
  KRK
  ANGGOTA
}

enum JenisRegu {
  KAPAL
  DARAT
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(ANGGOTA)
  reguId    Int?
  regu      Regu?    @relation(fields: [reguId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Regu {
  id           Int         @id @default(autoincrement())
  nomorKRK     String      @unique
  jenis        JenisRegu   @default(KAPAL)
  namaKepala   String?
  totalAnggota Int         @default(0)
  lastUsed     DateTime    @default(now())
  anggota      User[]
  jadwal       Jadwal[]
  izinKerjas   IzinKerja[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Shift {
  id         Int      @id @default(autoincrement())
  nama       String
  jamMulai   String
  jamSelesai String
  status     String   @default("AKTIF")
  createdAt  DateTime @default(now())
  jadwals    Jadwal[]
}

model Jadwal {
  id        Int      @id @default(autoincrement())
  tanggal   DateTime @default(now())
  reguId    Int
  regu      Regu     @relation(fields: [reguId], references: [id])
  shiftId   Int
  shift     Shift    @relation(fields: [shiftId], references: [id])
  jenis     String
  namaKapal String?
  status    String   @default("Aanvraag")
  createdAt DateTime @default(now())
}

model IzinKerja {
  id          Int      @id @default(autoincrement())
  tanggal     DateTime @default(now())
  reguId      Int
  regu        Regu     @relation(fields: [reguId], references: [id])
  alasan      String   @db.Text
  status      String   @default("Menunggu Persetujuan")
  isProcessed Boolean  @default(false)
  shiftId     Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
